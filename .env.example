# Database Configuration
DB_HOST=localhost
DB_PORT=3306
DB_NAME=hatamo
DB_USER=root
DB_PASSWORD=rootpassword

# Redis Configuration
REDIS_HOST=localhost
REDIS_PORT=6379

# Server Configuration
SERVER_PORT=8080

